    "typecheck": "tsc --noEmit",
    "test": "tsx --test server/__tests__/*.test.ts"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
