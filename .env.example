# PostgreSQL connection string
# Primjer: postgresql://user:password@localhost:5432/maky_db
DATABASE_URL="postgresql://user:password@localhost:5432/maky_db"

# Lozinka za admin panel (promijenite ovo!)
ADMIN_PASSWORD="vasa_sigurna_lozinka"

# JWT tajni kljuc (promijenite ovo! Koristite dugacak, nasumican string)
JWT_SECRET="vasa_jwt_tajna_vrijednost_min_32_karaktera"

# Port na kojem server slusa (default: 3001 za dev, 3000 za prod)
PORT=3001

# "production" na VPS-u
NODE_ENV="development"

# App URL (za OAuth callback i slicno, opciono)
APP_URL="https://maky.beauty"
