# ─────────────────────────────────────────────────────────────────────────────
# Maky Beauty Bar — konfiguracija
#
# Server NEĆE da se pokrene ako neka obavezna vrijednost nedostaje ili je
# ostavljena na primjer-vrijednosti ispod. To je namjerno: ranije je nedostajući
# JWT_SECRET tiho pretvarao admin panel u javno dostupan panel.
# ─────────────────────────────────────────────────────────────────────────────

# OBAVEZNO — PostgreSQL konekcija
DATABASE_URL="postgresql://user:password@localhost:5432/maky_db"

# OBAVEZNO — lozinka za admin panel (min. 12 znakova u produkciji)
ADMIN_PASSWORD="promijenite_ovu_lozinku"

# OBAVEZNO — JWT tajni ključ (min. 32 znaka, preporučeno 64+)
# Generiši sa:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="promijenite_ovaj_kljuc_generisanim_nasumicnim_stringom"

# Port na kojem server sluša (default: 3001)
PORT=3001

# "production" na VPS-u, "development" lokalno
NODE_ENV="development"
